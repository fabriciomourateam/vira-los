# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:8080

# URL pública do servidor (obrigatório para Instagram — use ngrok localmente)
# Ex local:    SERVER_URL=https://seu-id.ngrok.io
# Ex produção: SERVER_URL=https://seu-app.railway.app
SERVER_URL=http://localhost:3001

# ── Instagram Graph API ───────────────────────────────────────────────────────
# Crie em: https://developers.facebook.com → Meu App → Configurações Básicas
# Precisa de: conta Instagram Business/Creator vinculada a uma Página do Facebook
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/platforms/instagram/callback

# ── TikTok Content Posting API v2 ────────────────────────────────────────────
# Crie em: https://developers.tiktok.com → Manage Apps
# Escopos necessários: user.info.basic, video.upload, video.publish
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3001/api/platforms/tiktok/callback

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com → APIs & Services → Credenciais
# Ative: YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/platforms/youtube/callback

# ── Unsplash API ──────────────────────────────────────────────────────────────
# Crie em: https://unsplash.com/developers → New Application
# Usado pelo gerador de carrossel para buscar imagens retratos
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
UNSPLASH_APP_ID=

# ── Pexels API ────────────────────────────────────────────────────────────────
# Crie em: https://www.pexels.com/api/ → Get Started (gratuito)
# A chave é usada diretamente como header Authorization.
# Usado em dois lugares:
#   1. Fallback de imagens do gerador Básico (quando Unsplash falhar)
#   2. Fonte primária da Máquina de Carrosséis — proxy CORS-free em /api/pexels
#      e substituição automática de placeholders PEXELS:query no HTML gerado.
PEXELS_API_KEY=
